<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="FullCompo.App.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <sty:FluentAvaloniaTheme />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="ThemeBackgroundColor" Color="#CC1E1E1E" />
        <SolidColorBrush x:Key="ThemeForegroundColor" Color="White" />
        <SolidColorBrush x:Key="ThemeAccentColor" Color="#FF4A90E2" />
        <SolidColorBrush x:Key="ThemeBorderColor" Color="#55FFFFFF" />
        <x:Double x:Key="ThemeBorderThickness">1</x:Double>
        <CornerRadius x:Key="ThemeCornerRadius">12</CornerRadius>
        <x:Double x:Key="ThemeFontSizeScale">1.0</x:Double>
        <x:Double x:Key="ThemeOpacity">0.9</x:Double>
    </Application.Resources>
</Application>
